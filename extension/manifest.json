{
    "manifest_version": 3,
    "name": "Prompt Wallet Capture",
    "version": "1.0.0",
    "description": "Right click highlighted text to send it directly to your PromptWallet library.",
    "permissions": [
        "contextMenus",
        "activeTab",
        "scripting"
    ],
    "host_permissions": [
        "http://localhost:3000/*",
        "https://*/*"
    ],
    "background": {
        "service_worker": "background.js"
    }
}